# EazeNote – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Get a free API key at https://console.groq.com  (recommended)
# or at https://www.together.ai
LLM_API_KEY=your_api_key_here

# "groq" or "together"
LLM_PROVIDER=groq

# Model name – defaults are set in rag_pipeline.py based on provider.
# Override here if needed:
# LLM_MODEL=llama3-8b-8192          # Groq
# LLM_MODEL=meta-llama/Llama-3-8b-chat-hf  # Together AI

# ── ChromaDB ─────────────────────────────────────────────────────────────────
# Persistent storage directory (must be writable on your host / Render disk)
CHROMA_PERSIST_DIR=/data/chroma

# ── Server ───────────────────────────────────────────────────────────────────
# Render injects PORT automatically; 10000 is the default for Render web services
PORT=10000
